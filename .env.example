# ── Recommended: session token (login endpoint not yet discovered) ─────────────
#
# How to get your session token:
#   1. Log in at trainheroic.com
#   2. Open DevTools (F12) → Network tab
#   3. Click any request to api.trainheroic.com
#   4. Under Request Headers, find "session-token"
#   5. Copy that value here
#
TRAINHEROIC_SESSION_TOKEN=paste-your-session-token-here

# ── Alternative: email + password ─────────────────────────────────────────────
# The login endpoint hasn't been confirmed yet — this may not work.
# TRAINHEROIC_EMAIL=you@example.com
# TRAINHEROIC_PASSWORD=yourpassword

# ── Remote deployment (HTTP transport) ────────────────────────────────────────
# MCP_TRANSPORT=http
# MCP_AUTH_TOKEN=generate-with-make-generate-token
