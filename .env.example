# ── Preferred: email + password ───────────────────────────────────────────────
# The server logs in automatically on startup and caches the session token to
# ~/.config/trainheroic/session.json. Re-login happens automatically if it expires.
#
TRAINHEROIC_EMAIL=you@example.com
TRAINHEROIC_PASSWORD=yourpassword

# ── Alternative: session token directly ───────────────────────────────────────
# Use this if you prefer not to store your password, or need to bypass login.
#
# How to get your session token:
#   1. Log in at trainheroic.com
#   2. Open DevTools (F12) → Network tab
#   3. Click any request to api.trainheroic.com
#   4. Under Request Headers, find "session-token"
#   5. Copy that value here
#
# TRAINHEROIC_SESSION_TOKEN=<your-session-token>

# ── Remote deployment (HTTP transport) ────────────────────────────────────────
# MCP_TRANSPORT=http
# MCP_AUTH_TOKEN=generate-with-make-generate-token
